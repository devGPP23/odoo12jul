generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  asset_manager
  dept_head
  employee
}

enum UserStatus {
  active
  inactive
}

enum DeptStatus {
  active
  inactive
}

enum AssetCondition {
  new_condition
  good
  fair
  poor
  damaged
}

enum AssetStatus {
  available
  allocated
  reserved
  under_maintenance
  lost
  retired
  disposed
}

enum AllocationStatus {
  active
  returned
  transferred
  overdue
}

enum TransferStatus {
  pending
  approved
  rejected
}

enum BookingStatus {
  upcoming
  ongoing
  completed
  cancelled
}

enum MaintenancePriority {
  low
  medium
  high
  critical
}

enum MaintenanceStatus {
  pending
  approved
  rejected
  assigned
  in_progress
  resolved
}

enum AuditCycleStatus {
  open
  in_progress
  closed
}

enum AuditItemResult {
  pending
  verified
  missing
  damaged
}

enum AuditScopeType {
  department
  location
}

// ──────────────────────────────────────
// Core Tables
// ──────────────────────────────────────

model Department {
  id              Int           @id @default(autoincrement())
  name            String        @unique @db.VarChar(100)
  parentDeptId    Int?          @map("parent_dept_id")
  parentDept      Department?   @relation("DeptHierarchy", fields: [parentDeptId], references: [id], onDelete: SetNull)
  childDepts      Department[]  @relation("DeptHierarchy")
  headId          Int?          @map("head_id")
  head            User?         @relation("DeptHead", fields: [headId], references: [id], onDelete: SetNull)
  status          DeptStatus    @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  employees       User[]        @relation("DeptEmployees")
  assets          Asset[]
  allocations     Allocation[]  @relation("AllocDept")

  @@map("departments")
}

model User {
  id              Int           @id @default(autoincrement())
  name            String        @db.VarChar(100)
  email           String        @unique @db.VarChar(255)
  passwordHash    String        @map("password_hash") @db.VarChar(255)
  role            Role          @default(employee)
  roleVersion     Int           @default(0) @map("role_version")
  departmentId    Int?          @map("department_id")
  department      Department?   @relation("DeptEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  status          UserStatus    @default(active)
  resetToken      String?       @map("reset_token") @db.VarChar(255)
  resetTokenExp   DateTime?     @map("reset_token_exp")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  headOfDepts     Department[]  @relation("DeptHead")
  allocationsHeld Allocation[]  @relation("AllocUser")
  allocatedBy     Allocation[]  @relation("AllocBy")
  bookings        Booking[]
  maintenanceRaised    MaintenanceRequest[] @relation("MaintRaisedBy")
  maintenanceApproved  MaintenanceRequest[] @relation("MaintApprovedBy")
  maintenanceTech      MaintenanceRequest[] @relation("MaintTech")
  transfersFrom   TransferRequest[] @relation("TransFrom")
  transfersTo     TransferRequest[] @relation("TransTo")
  transfersReqBy  TransferRequest[] @relation("TransReqBy")
  transfersApprBy TransferRequest[] @relation("TransApprBy")
  auditCyclesCreated AuditCycle[]
  auditAssignments   AuditAssignment[]
  auditItemsMarked   AuditItem[]

  @@map("users")
}

model AssetCategory {
  id              Int           @id @default(autoincrement())
  name            String        @unique @db.VarChar(100)
  description     String?
  customFields    Json          @default("{}") @map("custom_fields")
  status          DeptStatus    @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  assets          Asset[]

  @@map("asset_categories")
}

model Asset {
  id                Int           @id @default(autoincrement())
  name              String        @db.VarChar(200)
  assetTag          String        @unique @map("asset_tag") @db.VarChar(20)
  serialNumber      String?       @map("serial_number") @db.VarChar(100)
  categoryId        Int           @map("category_id")
  category          AssetCategory @relation(fields: [categoryId], references: [id])
  departmentId      Int?          @map("department_id")
  department        Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  acquisitionDate   DateTime?     @map("acquisition_date") @db.Date
  acquisitionCost   Decimal?      @map("acquisition_cost") @db.Decimal(12, 2)
  condition         AssetCondition @default(new_condition)
  location          String?       @db.VarChar(200)
  status            AssetStatus   @default(available)
  isBookable        Boolean       @default(false) @map("is_bookable")
  photoUrl          String?       @map("photo_url") @db.VarChar(500)
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  allocations       Allocation[]
  bookings          Booking[]
  maintenanceReqs   MaintenanceRequest[]
  auditItems        AuditItem[]
  transferRequests  TransferRequest[]

  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@map("assets")
}

model Allocation {
  id                    Int              @id @default(autoincrement())
  assetId               Int              @map("asset_id")
  asset                 Asset            @relation(fields: [assetId], references: [id])
  employeeHolderId      Int?             @map("employee_holder_id")
  employeeHolder        User?            @relation("AllocUser", fields: [employeeHolderId], references: [id])
  departmentHolderId    Int?             @map("department_holder_id")
  departmentHolder      Department?      @relation("AllocDept", fields: [departmentHolderId], references: [id])
  allocatedById         Int              @map("allocated_by")
  allocatedBy           User             @relation("AllocBy", fields: [allocatedById], references: [id])
  allocationDate        DateTime         @default(now()) @map("allocation_date")
  expectedReturnDate    DateTime?        @map("expected_return_date") @db.Date
  actualReturnDate      DateTime?        @map("actual_return_date") @db.Date
  returnCondition       String?          @map("return_condition") @db.VarChar(30)
  returnNotes           String?          @map("return_notes")
  status                AllocationStatus @default(active)
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  transferRequests      TransferRequest[]

  @@map("allocations")
}

model TransferRequest {
  id              Int             @id @default(autoincrement())
  assetId         Int             @map("asset_id")
  asset           Asset           @relation(fields: [assetId], references: [id])
  allocationId    Int             @map("allocation_id")
  allocation      Allocation      @relation(fields: [allocationId], references: [id])
  fromUserId      Int             @map("from_user_id")
  fromUser        User            @relation("TransFrom", fields: [fromUserId], references: [id])
  toUserId        Int             @map("to_user_id")
  toUser          User            @relation("TransTo", fields: [toUserId], references: [id])
  requestedById   Int             @map("requested_by")
  requestedBy     User            @relation("TransReqBy", fields: [requestedById], references: [id])
  approvedById    Int?            @map("approved_by")
  approvedBy      User?           @relation("TransApprBy", fields: [approvedById], references: [id])
  status          TransferStatus  @default(pending)
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("transfer_requests")
}

model Booking {
  id              Int             @id @default(autoincrement())
  assetId         Int             @map("asset_id")
  asset           Asset           @relation(fields: [assetId], references: [id])
  bookedById      Int             @map("booked_by")
  bookedBy        User            @relation(fields: [bookedById], references: [id])
  startTime       DateTime        @map("start_time")
  endTime         DateTime        @map("end_time")
  status          BookingStatus   @default(upcoming)
  purpose         String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([assetId])
  @@index([bookedById])
  @@map("bookings")
}

model MaintenanceRequest {
  id                Int                 @id @default(autoincrement())
  assetId           Int                 @map("asset_id")
  asset             Asset               @relation(fields: [assetId], references: [id])
  raisedById        Int                 @map("raised_by")
  raisedBy          User                @relation("MaintRaisedBy", fields: [raisedById], references: [id])
  description       String
  priority          MaintenancePriority @default(medium)
  status            MaintenanceStatus   @default(pending)
  previousAssetStatus String?           @map("previous_asset_status") @db.VarChar(30)
  approvedById      Int?                @map("approved_by")
  approvedBy        User?               @relation("MaintApprovedBy", fields: [approvedById], references: [id])
  technicianId      Int?                @map("technician_id")
  technician        User?               @relation("MaintTech", fields: [technicianId], references: [id])
  photoUrl          String?             @map("photo_url") @db.VarChar(500)
  resolvedAt        DateTime?           @map("resolved_at")
  resolutionNotes   String?             @map("resolution_notes")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([assetId])
  @@index([status])
  @@map("maintenance_requests")
}

model AuditCycle {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(200)
  scopeType       AuditScopeType   @map("scope_type")
  scopeValue      String           @map("scope_value") @db.VarChar(200)
  startDate       DateTime         @map("start_date") @db.Date
  endDate         DateTime         @map("end_date") @db.Date
  status          AuditCycleStatus @default(open)
  createdById     Int              @map("created_by")
  createdBy       User             @relation(fields: [createdById], references: [id])
  closedAt        DateTime?        @map("closed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  assignments     AuditAssignment[]
  items           AuditItem[]

  @@map("audit_cycles")
}

model AuditAssignment {
  id              Int        @id @default(autoincrement())
  auditCycleId    Int        @map("audit_cycle_id")
  auditCycle      AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditorId       Int        @map("auditor_id")
  auditor         User       @relation(fields: [auditorId], references: [id])
  createdAt       DateTime   @default(now()) @map("created_at")

  @@unique([auditCycleId, auditorId])
  @@map("audit_assignments")
}

model AuditItem {
  id              Int             @id @default(autoincrement())
  auditCycleId    Int             @map("audit_cycle_id")
  auditCycle      AuditCycle      @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId         Int             @map("asset_id")
  asset           Asset           @relation(fields: [assetId], references: [id])
  auditorId       Int?            @map("auditor_id")
  auditor         User?           @relation(fields: [auditorId], references: [id])
  result          AuditItemResult @default(pending)
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([auditCycleId, assetId])
  @@index([auditCycleId])
  @@map("audit_items")
}
