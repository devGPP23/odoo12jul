// ─── AssetFlow — Prisma Schema ───
// All core relational entities live here.
// Booking overlap constraint is added via a hand-edited migration (see migrations/).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────────

enum EmployeeRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditScopeType {
  DEPARTMENT
  LOCATION
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  VERIFIED
  MISSING
  DAMAGED
}

// ────────────────────────────────────────────────────────────
// Models
// ────────────────────────────────────────────────────────────

model Department {
  id                 String       @id @default(uuid())
  name               String       @unique
  parentDepartmentId String?      @map("parent_department_id")
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")
  headEmployeeId     String?      @map("head_employee_id")
  headEmployee       Employee?    @relation("DepartmentHead", fields: [headEmployeeId], references: [id])
  status             EntityStatus @default(ACTIVE)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Reverse relations
  employees              Employee[]       @relation("EmployeeDepartment")
  departmentAllocations  Allocation[]     @relation("DepartmentHolder")

  @@map("departments")
}

model Employee {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  departmentId String?      @map("department_id")
  department   Department?  @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  role         EmployeeRole @default(EMPLOYEE)
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Reverse relations
  headOfDepartments       Department[]         @relation("DepartmentHead")
  employeeAllocations     Allocation[]         @relation("EmployeeHolder")
  bookings                Booking[]
  maintenanceRaised       MaintenanceRequest[] @relation("MaintenanceRequester")
  maintenanceAssigned     MaintenanceRequest[] @relation("MaintenanceTechnician")
  maintenanceApproved     MaintenanceRequest[] @relation("MaintenanceApprover")
  transfersRequested      TransferRequest[]    @relation("TransferRequester")
  transfersApproved       TransferRequest[]    @relation("TransferApprover")
  transfersFrom           TransferRequest[]    @relation("TransferFrom")
  transfersTo             TransferRequest[]    @relation("TransferTo")
  auditAssignments        AuditAssignment[]
  auditItemsMarked        AuditItem[]

  @@map("employees")
}

model AssetCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  customFields Json?    @map("custom_fields") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assets Asset[]

  @@map("asset_categories")
}

model Asset {
  id              String         @id @default(uuid())
  name            String
  categoryId      String         @map("category_id")
  category        AssetCategory  @relation(fields: [categoryId], references: [id])
  assetTag        String         @unique @map("asset_tag")
  serialNumber    String?        @unique @map("serial_number")
  acquisitionDate DateTime?      @map("acquisition_date")
  acquisitionCost Decimal?       @map("acquisition_cost") @db.Decimal(12, 2)
  condition       AssetCondition @default(NEW)
  location        String?
  photoUrl        String?        @map("photo_url")
  isBookable      Boolean        @default(false) @map("is_bookable")
  status          AssetStatus    @default(AVAILABLE)
  qrCode          String?        @map("qr_code")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Reverse relations
  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  transferRequests    TransferRequest[]

  @@map("assets")
}

/// Tracks who holds an asset. Polymorphic holder: exactly one of
/// employeeHolderId / departmentHolderId must be non-null.
/// CHECK constraint added via raw migration.
model Allocation {
  id                 String           @id @default(uuid())
  assetId            String           @map("asset_id")
  asset              Asset            @relation(fields: [assetId], references: [id])
  employeeHolderId   String?          @map("employee_holder_id")
  employeeHolder     Employee?        @relation("EmployeeHolder", fields: [employeeHolderId], references: [id])
  departmentHolderId String?          @map("department_holder_id")
  departmentHolder   Department?      @relation("DepartmentHolder", fields: [departmentHolderId], references: [id])
  allocatedAt        DateTime         @default(now()) @map("allocated_at")
  expectedReturnDate DateTime?        @map("expected_return_date")
  actualReturnDate   DateTime?        @map("actual_return_date")
  status             AllocationStatus @default(ACTIVE)
  checkinNotes       String?          @map("checkin_notes")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("allocations")
}

model TransferRequest {
  id            String         @id @default(uuid())
  assetId       String         @map("asset_id")
  asset         Asset          @relation(fields: [assetId], references: [id])
  fromHolderId  String         @map("from_holder_id")
  fromHolder    Employee       @relation("TransferFrom", fields: [fromHolderId], references: [id])
  toHolderId    String         @map("to_holder_id")
  toHolder      Employee       @relation("TransferTo", fields: [toHolderId], references: [id])
  requestedById String         @map("requested_by_id")
  requestedBy   Employee       @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedById  String?        @map("approved_by_id")
  approvedBy    Employee?      @relation("TransferApprover", fields: [approvedById], references: [id])
  status        TransferStatus @default(REQUESTED)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("transfer_requests")
}

/// Booking uses startTime/endTime instead of tsrange for Prisma compatibility.
/// The EXCLUDE USING gist constraint is added via a hand-edited migration using
/// tstzrange(start_time, end_time) to reject overlapping bookings at the DB layer.
model Booking {
  id         String        @id @default(uuid())
  assetId    String        @map("asset_id")
  asset      Asset         @relation(fields: [assetId], references: [id])
  bookedById String        @map("booked_by_id")
  bookedBy   Employee      @relation(fields: [bookedById], references: [id])
  startTime  DateTime      @map("start_time")
  endTime    DateTime      @map("end_time")
  status     BookingStatus @default(UPCOMING)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@map("bookings")
}

model MaintenanceRequest {
  id               String              @id @default(uuid())
  assetId          String              @map("asset_id")
  asset            Asset               @relation(fields: [assetId], references: [id])
  raisedById       String              @map("raised_by_id")
  raisedBy         Employee            @relation("MaintenanceRequester", fields: [raisedById], references: [id])
  issueDescription String              @map("issue_description")
  priority         MaintenancePriority @default(MEDIUM)
  photoUrl         String?             @map("photo_url")
  status           MaintenanceStatus   @default(PENDING)
  approvedById     String?             @map("approved_by_id")
  approvedBy       Employee?           @relation("MaintenanceApprover", fields: [approvedById], references: [id])
  technicianId     String?             @map("technician_id")
  technician       Employee?           @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  resolvedAt       DateTime?           @map("resolved_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@map("maintenance_requests")
}

model AuditCycle {
  id         String           @id @default(uuid())
  scopeType  AuditScopeType   @map("scope_type")
  scopeValue String           @map("scope_value")
  dateStart  DateTime         @map("date_start")
  dateEnd    DateTime         @map("date_end")
  status     AuditCycleStatus @default(OPEN)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  assignments AuditAssignment[]
  items       AuditItem[]

  @@map("audit_cycles")
}

model AuditAssignment {
  id           String     @id @default(uuid())
  auditCycleId String     @map("audit_cycle_id")
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  auditorId    String     @map("auditor_id")
  auditor      Employee   @relation(fields: [auditorId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([auditCycleId, auditorId])
  @@map("audit_assignments")
}

model AuditItem {
  id           String       @id @default(uuid())
  auditCycleId String       @map("audit_cycle_id")
  auditCycle   AuditCycle   @relation(fields: [auditCycleId], references: [id])
  assetId      String       @map("asset_id")
  asset        Asset        @relation(fields: [assetId], references: [id])
  auditorId    String       @map("auditor_id")
  auditor      Employee     @relation(fields: [auditorId], references: [id])
  result       AuditResult?
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([auditCycleId, assetId])
  @@map("audit_items")
}
